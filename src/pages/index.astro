---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import KumoMark from '../components/KumoMark.astro';
import ArchitectureExplorer from '../components/ArchitectureExplorer';
import '../components/ArchitectureExplorer.css';

const pillars = [
  {
    number: '01',
    title: 'Authority you can name',
    body: 'Memory, IPC, interrupts, and processes are reached through typed, unforgeable handles—not ambient privilege.',
    detail: 'CAPABILITY MODEL',
  },
  {
    number: '02',
    title: 'A deliberately small core',
    body: 'MUREX keeps policy outside the privileged kernel, reducing the trusted computing base to mechanisms that must be there.',
    detail: 'MICROKERNEL',
  },
  {
    number: '03',
    title: 'Hardware without mythology',
    body: 'A clean HAL separates architecture and board concerns across arm64 and x86_64, from QEMU to real machines.',
    detail: 'PORTABLE HAL',
  },
];

const targets = [
  ['ThinkPad X13s', 'arm64 · metal baseline', 'Proven'],
  ['Raspberry Pi 5', 'arm64 · BCM2712', 'Observed'],
  ['HP Z4 G4', 'x86_64 · Xeon', 'Proven'],
  ['Orange Pi 5 Plus', 'arm64 · RK3588', 'Next gate'],
];
---

<BaseLayout>
  <SiteHeader />

  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-copy shell">
        <div class="hero-left">
          <p class="eyebrow hero-eyebrow">KUMO / 雲 / Independent systems project</p>
          <h1 id="hero-title">A serene<br /><em>microkernel.</em></h1>
          <p class="hero-lede">A clean-room, capability-based operating system in Rust—built to make authority explicit, failures containable, and the machine understandable again.</p>
          <div class="hero-actions">
            <a class="primary-action" href="#project">Explore KUMO <span aria-hidden="true">↓</span></a>
            <a class="secondary-action link-arrow" href="https://github.com/crux161/kumo" target="_blank" rel="noreferrer">View source</a>
          </div>
        </div>
        <figure class="hero-media">
          <img src="/images/kumo-3d-red.jpg" alt="Black KUMO cloud mark and wordmark on a vivid red field" width="1536" height="1024" />
          <figcaption><span>FIG. 001</span><span>THE FLYING NIMBUS SYSTEM</span></figcaption>
        </figure>
      </div>
      <div class="hero-metrics shell" aria-label="KUMO status">
        <div><strong>#![no_std]</strong><span>Rust foundation</span></div>
        <div><strong>2</strong><span>architectures</span></div>
        <div><strong>EL0</strong><span>root server alive</span></div>
        <div><strong>Active</strong><span>research & bring-up</span></div>
      </div>
    </section>

    <section class="manifesto shell" id="project" aria-labelledby="project-title">
      <div class="section-index">
        <span>01</span>
        <p class="eyebrow">The project</p>
      </div>
      <div class="manifesto-main">
        <p class="intro">Clouds are soft at the edge.<br />The rules inside should be precise.</p>
        <h2 id="project-title">KUMO strips the privileged kernel down to the irreducible minimum: address spaces, scheduling, IPC, capabilities, traps, and hardware confinement.</h2>
        <div class="manifesto-tail">
          <p>The larger <strong>Flying Nimbus</strong> system grows from that quiet center into a UNIX-like environment: native KUMO services, a Rust userspace, persistent storage, graphics, and a demand-driven Linux persona.</p>
          <p>It already boots a real EL0 root server and user processes. It is not a daily-driver OS yet—and the work never pretends otherwise.</p>
        </div>
      </div>
    </section>

    <section class="pillars" aria-labelledby="principles-title">
      <div class="shell pillars-heading">
        <div class="section-index light">
          <span>02</span>
          <p class="eyebrow">Design principles</p>
        </div>
        <h2 id="principles-title">Resilience is an<br />architectural choice.</h2>
      </div>
      <div class="shell pillar-grid">
        {pillars.map((pillar) => (
          <article class="pillar-card">
            <span class="pillar-number">{pillar.number}</span>
            <h3>{pillar.title}</h3>
            <p>{pillar.body}</p>
            <span class="pillar-detail">{pillar.detail}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="system-map shell" id="architecture" aria-labelledby="architecture-title">
      <div class="section-index">
        <span>03</span>
        <p class="eyebrow">Site system</p>
      </div>
      <div class="map-heading">
        <h2 id="architecture-title">Content first.<br />Runtime by invitation.</h2>
        <p>This site mirrors KUMO’s bias toward small trusted cores. Most of the experience arrives as static HTML. Interactivity is isolated, visible, and earned.</p>
      </div>
      <ArchitectureExplorer client:visible />
    </section>

    <section class="hardware" aria-labelledby="hardware-title">
      <div class="shell hardware-grid">
        <div class="hardware-art">
          <img src="/images/kumo-full-color.jpg" alt="Iridescent KUMO cloud floating over a soft cream background" width="1024" height="1024" loading="lazy" />
          <div class="art-label"><span>LIGHTNESS / WITHOUT FRAGILITY</span><span>雲</span></div>
        </div>
        <div class="hardware-copy">
          <div class="section-index">
            <span>04</span>
            <p class="eyebrow">Hardware fieldwork</p>
          </div>
          <h2 id="hardware-title">From emulation<br />to metal.</h2>
          <p class="hardware-lede">KUMO separates a target that builds from one that has completed a physical boot. Evidence matters.</p>
          <div class="target-list">
            {targets.map(([name, detail, status]) => (
              <div class="target-row">
                <strong>{name}</strong>
                <span>{detail}</span>
                <em>{status}</em>
              </div>
            ))}
          </div>
          <a class="text-link link-arrow" href="https://github.com/crux161/kumo#-hardware-targets" target="_blank" rel="noreferrer">Review the hardware matrix</a>
        </div>
      </div>
    </section>

    <section class="notes shell" id="notes" aria-labelledby="notes-title">
      <div class="section-index">
        <span>05</span>
        <p class="eyebrow">Field notes</p>
      </div>
      <div class="notes-heading">
        <h2 id="notes-title">Working in public.</h2>
        <p>Architecture notes, bring-up journals, and the reasoning behind the machine.</p>
      </div>
      <a class="featured-note" href="/notes/architecture">
        <span class="note-meta">ARCHITECTURE · 07.15.2026</span>
	<strong>Resilience and security by default.</strong>
	<p>"The Master does nothing, yet he leaves nothing undone." <br/><br/> Informed by the foundations of computing in UNIX, but inspired by Daoism. If "everything is a file" is the old philosophy, here we will let <i>the thing speak for itself.</i> </p>
        <span class="note-arrow" aria-hidden="true">→</span>
      </a>
      <div class="coming-notes">
        <div><span>BRING-UP</span><strong>Orange Pi, first light</strong><em>In progress</em></div>
        <div><span>DESIGN</span><strong>Authority without ambient privilege</strong><em>Drafting</em></div>
      </div>
    </section>

    <section class="closing" aria-label="KUMO source call to action">
      <div class="shell closing-inner">
        <p class="eyebrow">KUMO / FLYING NIMBUS</p>
        <h2>Build your castle<br />in the clouds.</h2>
        <a href="https://github.com/crux161/kumo" target="_blank" rel="noreferrer">Read the source <span aria-hidden="true">↗</span></a>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="shell footer-grid">
      <KumoMark inverted />
      <p>A personal systems project by Crux.<br />Designed and built in the open.</p>
      <div class="footer-links"><a href="#project">Project</a><a href="#notes">Notes</a><a href="https://github.com/crux161/kumo">GitHub</a></div>
      <span class="copyright">© 2026 KUMO</span>
    </div>
  </footer>
</BaseLayout>

<style>
  .hero { background:#ecebe6; }
  .hero-copy { display:grid; grid-template-columns:minmax(0, .94fr) minmax(380px, 1.06fr); min-height:calc(100vh - 4.2rem); padding-right:0; }
  .hero-left { display:flex; flex-direction:column; justify-content:center; padding:clamp(4rem, 8vw, 8rem) clamp(2rem, 6vw, 7rem) clamp(4rem, 8vw, 8rem) 0; }
  .hero-eyebrow { margin-bottom:clamp(2.5rem, 5vw, 5rem); }
  .hero h1 { margin:0; font-size:clamp(4.5rem, 8.7vw, 9.2rem); font-weight:460; line-height:.82; letter-spacing:-.082em; }
  .hero h1 em { color:var(--red); font-family:Georgia, 'Times New Roman', serif; font-weight:400; }
  .hero-lede { max-width:660px; margin:clamp(2rem,4vw,4rem) 0 0; color:#494946; font-size:clamp(1.05rem,1.45vw,1.3rem); line-height:1.6; }
  .hero-actions { display:flex; flex-wrap:wrap; align-items:center; gap:1.5rem 2rem; margin-top:3rem; }
  .primary-action { display:inline-flex; align-items:center; justify-content:space-between; gap:3rem; min-width:15rem; padding:1rem 1.2rem; color:#fff; background:var(--red); font-size:.82rem; text-decoration:none; }
  .primary-action:hover { background:var(--red-dark); }
  .secondary-action { font-size:.82rem; }
  .hero-media { position:relative; min-height:700px; margin:0; overflow:hidden; background:#d51b18; }
  .hero-media img { width:100%; height:100%; object-fit:cover; }
  .hero-media::after { position:absolute; inset:0; content:""; background:linear-gradient(180deg,transparent 65%,rgba(0,0,0,.35)); pointer-events:none; }
  .hero-media figcaption { position:absolute; z-index:1; right:1.5rem; bottom:1.3rem; left:1.5rem; display:flex; justify-content:space-between; color:#fff; font:500 .62rem/1 var(--font-mono); letter-spacing:.1em; }
  .hero-metrics { display:grid; grid-template-columns:repeat(4,1fr); padding-right:0; border-top:1px solid var(--line); }
  .hero-metrics div { display:flex; flex-direction:column; gap:.5rem; min-height:8.5rem; padding:1.6rem; border-right:1px solid var(--line); }
  .hero-metrics strong { font-size:1.7rem; font-weight:500; letter-spacing:-.04em; }
  .hero-metrics span { color:#6a6a66; font:500 .66rem/1 var(--font-mono); text-transform:uppercase; letter-spacing:.09em; }

  .section-index { display:grid; grid-template-columns:3.2rem 1fr; gap:1rem; align-items:start; }
  .section-index > span { color:#8c8c87; font:500 .7rem/1 var(--font-mono); }
  .section-index .eyebrow::before { display:none; }
  .manifesto { display:grid; grid-template-columns:minmax(180px,.35fr) minmax(0,1fr); gap:3rem; padding-top:clamp(6rem,12vw,12rem); padding-bottom:clamp(6rem,12vw,12rem); }
  .manifesto-main { max-width:1100px; }
  .intro { margin:0 0 4rem; color:var(--red); font:500 .82rem/1.5 var(--font-mono); text-transform:uppercase; letter-spacing:.04em; }
  .manifesto h2 { margin:0; font-size:clamp(2.5rem,5.5vw,6.2rem); font-weight:420; line-height:1.02; letter-spacing:-.062em; }
  .manifesto-tail { display:grid; grid-template-columns:repeat(2,1fr); gap:3rem; max-width:830px; margin:5rem 0 0 auto; }
  .manifesto-tail p { margin:0; color:#50504c; font-size:1rem; line-height:1.7; }
  .manifesto-tail strong { color:#111; }

  .pillars { padding:clamp(6rem,10vw,10rem) 0 0; color:#fff; background:#111; }
  .section-index.light > span, .section-index.light .eyebrow { color:#7c7c7c; }
  .pillars-heading { display:grid; grid-template-columns:minmax(180px,.35fr) 1fr; gap:3rem; align-items:start; }
  .pillars-heading h2 { margin:0 0 clamp(4rem,8vw,8rem); font-size:clamp(3.5rem,7.5vw,8.5rem); font-weight:420; line-height:.92; letter-spacing:-.072em; }
  .pillar-grid { display:grid; grid-template-columns:repeat(3,1fr); padding-right:0; }
  .pillar-card { position:relative; display:flex; flex-direction:column; min-height:35rem; padding:2rem; border-top:1px solid #383838; border-right:1px solid #383838; overflow:hidden; }
  .pillar-card::after { position:absolute; right:-6rem; bottom:-6rem; width:16rem; height:16rem; content:""; border:1px solid #2b2b2b; border-radius:50%; transition:transform .45s ease, border-color .45s ease; }
  .pillar-card:hover::after { transform:scale(1.45); border-color:#5c1010; }
  .pillar-number { color:#777; font:500 .68rem/1 var(--font-mono); }
  .pillar-card h3 { max-width:330px; margin:auto 0 1.5rem; font-size:clamp(2rem,3vw,3.4rem); font-weight:450; line-height:1; letter-spacing:-.05em; }
  .pillar-card p { max-width:390px; margin:0 0 3rem; color:#a6a6a6; line-height:1.6; }
  .pillar-detail { position:relative; z-index:1; color:#6e6e6e; font:500 .63rem/1 var(--font-mono); letter-spacing:.1em; }

  .system-map { padding-top:clamp(7rem,12vw,12rem); padding-bottom:clamp(7rem,12vw,12rem); }
  .map-heading { display:grid; grid-template-columns:1.3fr .7fr; gap:4rem; align-items:end; margin:3.5rem 0 5rem; }
  .map-heading h2 { margin:0; font-size:clamp(3.6rem,7vw,8rem); font-weight:420; line-height:.9; letter-spacing:-.072em; }
  .map-heading p { max-width:480px; margin:0 0 .5rem; color:#5a5a56; font-size:1.08rem; line-height:1.65; }

  .hardware { border-top:1px solid var(--line); background:#ecebe6; }
  .hardware-grid { display:grid; grid-template-columns:1fr 1fr; padding-left:0; }
  .hardware-art { position:relative; min-height:760px; background:#fff1dc; }
  .hardware-art img { width:100%; height:100%; object-fit:cover; }
  .art-label { position:absolute; right:1.5rem; bottom:1.5rem; left:1.5rem; display:flex; justify-content:space-between; color:#57524a; font:500 .62rem/1 var(--font-mono); letter-spacing:.09em; }
  .hardware-copy { padding:clamp(4rem,8vw,8rem); }
  .hardware-copy h2 { margin:4rem 0 2rem; font-size:clamp(3.5rem,6vw,7rem); font-weight:420; line-height:.9; letter-spacing:-.07em; }
  .hardware-lede { max-width:570px; color:#555550; font-size:1.12rem; line-height:1.65; }
  .target-list { margin:4rem 0 2.5rem; border-top:1px solid #c9c7c0; }
  .target-row { display:grid; grid-template-columns:1.2fr 1fr auto; gap:1rem; padding:1.2rem 0; border-bottom:1px solid #c9c7c0; }
  .target-row strong { font-size:.9rem; font-weight:600; }
  .target-row span, .target-row em { color:#6c6c67; font:500 .66rem/1.3 var(--font-mono); font-style:normal; text-transform:uppercase; }
  .target-row em { color:var(--red); }
  .text-link { font-size:.82rem; }

  .notes { padding-top:clamp(7rem,12vw,12rem); padding-bottom:clamp(7rem,12vw,12rem); }
  .notes-heading { display:grid; grid-template-columns:1fr .45fr; gap:4rem; align-items:end; margin:3rem 0 5rem; }
  .notes-heading h2 { margin:0; font-size:clamp(4rem,8vw,9rem); font-weight:420; line-height:.9; letter-spacing:-.075em; }
  .notes-heading p { margin:0 0 .6rem; color:#5d5d59; line-height:1.6; }
  .featured-note { position:relative; display:grid; grid-template-columns:.55fr 1.2fr .7fr auto; gap:2rem; align-items:start; padding:2.3rem 1.5rem; border-top:1px solid #111; border-bottom:1px solid var(--line); text-decoration:none; transition:background .2s; }
  .featured-note:hover { background:#fff; }
  .note-meta { color:#747470; font:500 .63rem/1.3 var(--font-mono); letter-spacing:.08em; }
  .featured-note strong { font-size:clamp(1.5rem,2.5vw,2.6rem); font-weight:500; line-height:1.05; letter-spacing:-.04em; }
  .featured-note p { margin:0; color:#62625e; line-height:1.55; }
  .note-arrow { color:var(--red); font-size:2rem; }
  .coming-notes { margin-left:calc(27.5% + 1rem); }
  .coming-notes div { display:grid; grid-template-columns:.65fr 1.2fr auto; gap:2rem; padding:1.5rem; border-bottom:1px solid var(--line); }
  .coming-notes span, .coming-notes em { color:#7a7a76; font:500 .63rem/1.3 var(--font-mono); font-style:normal; letter-spacing:.08em; }
  .coming-notes strong { font-weight:500; }

  .closing { color:#fff; background:var(--red); }
  .closing-inner { position:relative; min-height:70vh; padding-top:clamp(4rem,8vw,8rem); padding-bottom:clamp(4rem,8vw,8rem); overflow:hidden; }
  .closing-inner::after { position:absolute; right:-8vw; bottom:-42%; content:'雲'; color:rgba(130,0,0,.25); font-family:serif; font-size:min(50vw, 50rem); line-height:1; }
  .closing .eyebrow { color:rgba(255,255,255,.7); }
  .closing h2 { position:relative; z-index:1; margin:clamp(3rem,7vw,7rem) 0; font-size:clamp(4.5rem,10vw,11rem); font-weight:420; line-height:.82; letter-spacing:-.085em; }
  .closing a { position:relative; z-index:1; display:inline-flex; justify-content:space-between; gap:5rem; min-width:20rem; padding:1.2rem; border:1px solid rgba(255,255,255,.65); font-size:.85rem; text-decoration:none; transition:color .2s,background .2s; }
  .closing a:hover { color:var(--red); background:#fff; }

  .footer { color:#fff; background:#111; }
  .footer-grid { display:grid; grid-template-columns:1fr 1fr .65fr auto; gap:3rem; align-items:start; padding-top:4rem; padding-bottom:4rem; }
  .footer p { margin:0; color:#999; font-size:.82rem; line-height:1.6; }
  .footer-links { display:grid; gap:.7rem; }
  .footer-links a { color:#ccc; font-size:.8rem; text-decoration:none; }
  .copyright { color:#666; font:500 .62rem/1 var(--font-mono); }

  @media (max-width: 1000px) {
    .hero-copy { grid-template-columns:1fr; padding-right:clamp(1.25rem,4vw,4.5rem); }
    .hero-left { min-height:calc(80vh - 4rem); padding-right:0; }
    .hero-media { min-height:58vw; }
    .hero-metrics { padding-right:clamp(1.25rem,4vw,4.5rem); }
    .manifesto, .pillars-heading { grid-template-columns:1fr; }
    .pillar-grid { padding-right:clamp(1.25rem,4vw,4.5rem); }
    .pillar-card { min-height:28rem; }
    .map-heading { grid-template-columns:1fr; }
    .hardware-grid { grid-template-columns:1fr; padding-right:0; }
    .hardware-art { min-height:70vw; }
    .notes-heading { grid-template-columns:1fr; }
    .featured-note { grid-template-columns:.5fr 1.2fr auto; }
    .featured-note p { display:none; }
    .coming-notes { margin-left:0; }
    .footer-grid { grid-template-columns:1fr 1fr; }
  }

  @media (max-width: 700px) {
    .hero h1 { font-size:clamp(4.1rem,20vw,6.8rem); }
    .hero-metrics { grid-template-columns:repeat(2,1fr); }
    .hero-metrics div:nth-child(2) { border-right:0; }
    .manifesto { gap:4rem; }
    .manifesto-tail { grid-template-columns:1fr; gap:1.5rem; }
    .pillar-grid { grid-template-columns:1fr; }
    .pillar-card { min-height:25rem; }
    .hardware-copy { padding-inline:1.25rem; }
    .target-row { grid-template-columns:1fr auto; }
    .target-row span { grid-column:1 / -1; grid-row:2; }
    .featured-note { grid-template-columns:1fr auto; gap:1rem; padding-inline:0; }
    .featured-note strong { grid-column:1; }
    .note-arrow { grid-column:2; grid-row:1 / 3; }
    .coming-notes div { grid-template-columns:1fr auto; padding-inline:0; }
    .coming-notes strong { grid-column:1 / -1; grid-row:2; }
    .footer-grid { grid-template-columns:1fr; }
  }
</style>

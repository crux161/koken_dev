---
import KumoMark from './KumoMark.astro';
---

<header class="header">
  <div class="nav shell">
    <KumoMark inverted />
    <nav aria-label="Primary navigation">
      <a href="#project">Project</a>
      <a href="#architecture">Architecture</a>
      <a href="#notes">Notes</a>
      <a class="repo" href="https://github.com/crux161/kumo" target="_blank" rel="noreferrer">Source <span aria-hidden="true">↗</span></a>
    </nav>
    <details class="mobile-nav">
      <summary aria-label="Open navigation"><span></span><span></span></summary>
      <div class="mobile-panel">
        <a href="#project">Project</a>
        <a href="#architecture">Architecture</a>
        <a href="#notes">Notes</a>
      </div>
    </details>
  </div>
</header>

<style>
  .header { position:sticky; top:0; z-index:50; color:#fff; background:#111; border-bottom:1px solid #343434; }
  .nav { display:flex; align-items:center; justify-content:space-between; min-height:4.2rem; }
  nav { display:flex; align-items:stretch; align-self:stretch; }
  nav a { display:flex; align-items:center; padding:0 1.3rem; border-left:1px solid #343434; color:#c9c9c9; font-size:.82rem; text-decoration:none; transition:background .2s,color .2s; }
  nav a:hover { color:#fff; background:#242424; }
  nav .repo { color:#fff; background:var(--red); border-color:var(--red); }
  nav .repo:hover { background:#ef1818; }
  nav .repo span { margin-left:.55rem; }
  .mobile-nav { display:none; }
  @media (max-width: 760px) {
    nav { display:none; }
    .mobile-nav { display:block; position:relative; }
    summary { display:grid; gap:6px; cursor:pointer; list-style:none; padding:.75rem; }
    summary::-webkit-details-marker { display:none; }
    summary span { display:block; width:1.45rem; height:1px; background:#fff; }
    .mobile-panel { position:absolute; right:0; top:2.75rem; min-width:12rem; padding:.4rem; background:#111; border:1px solid #3a3a3a; }
    .mobile-panel a { display:block; padding:.9rem 1rem; color:#fff; text-decoration:none; border-bottom:1px solid #2d2d2d; }
  }
</style>
